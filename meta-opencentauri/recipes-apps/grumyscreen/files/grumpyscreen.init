#!/bin/sh
### BEGIN INIT INFO
# Provides:          grumpyscreen
# Required-Start:    $local_fs $network klipper moonraker
# Required-Stop:     $local_fs $network
# Default-Start:     2 3 4 5
# Default-Stop:     0 1 6
# Description:       Guppy Screen - Touch UI for Klipper
### END INIT INFO

GRUMPYSCREEN_EXEC=/usr/bin/grumpyscreen
PIDFILE=/var/run/gui.pid
export LVGL_EVDEV_DEV=${LVGL_EVDEV_DEV:-/dev/input/touchscreen0}

case "$1" in
    start)
        echo "Starting grumpyscreen..."
        # ponytail: wait for the DT-auto-probed touch input node to appear.
        for _ in 1 2 3 4 5; do
            [ -e /dev/input/touchscreen0 ] && break
            sleep 1
        done
        # Start grumpyscreen in the background
        start-stop-daemon -S -b -m -p "$PIDFILE" -x "$GRUMPYSCREEN_EXEC"
        ;;
    stop)
        echo "Stopping grumpyscreen..."
        start-stop-daemon -K -p "$PIDFILE" -R 10
        rm -f $PIDFILE
        ;;
    restart|force-reload)
        $0 stop
        sleep 1
        $0 start
        ;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            echo "grumpyscreen is running (PID $(cat "$PIDFILE"))"
        else
            echo "grumpyscreen is not running"
            return 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit $?

+    def _remove_pulldown(self, r):
+        if not self.pulldown_resistor:
+            return r
+        # The ADC sees the thermistor branch in parallel with pulldown_resistor.
+        r = min(r, self.pulldown_resistor * 0.999999)
+        return r * self.pulldown_resistor / (self.pulldown_resistor - r)
+
+    def _apply_pulldown(self, r):
+        if not self.pulldown_resistor:
+            return r
+        return r * self.pulldown_resistor / (r + self.pulldown_resistor)
+
     def calc_temp(self, adc):

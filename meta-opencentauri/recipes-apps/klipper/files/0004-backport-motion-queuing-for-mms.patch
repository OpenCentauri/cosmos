From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Anna <anna@enneo.ai>
Date: Sun, 4 May 2026 00:00:00 +0000
Subject: [PATCH] Backport motion_queuing module for BIGTREETECH MMS support

The BIGTREETECH MMS (Multi-Material System) Klipper plugin requires
the motion_queuing object that upstream Klipper introduced as part of
the toolhead step generation refactor (between Nov 2025 and Apr 2026).

Kalico has not adopted that refactor and lacks the steppersyncmgr_*
C primitives upstream uses. This patch adds a compatibility shim
implementing the subset of the motion_queuing Python API that MMS uses
on top of Kalico's existing trapq / itersolve / toolhead primitives.
It is loaded on demand via printer.load_object("motion_queuing") and
not used by core Kalico.

Behavior:
- allocate_trapq / lookup_trapq_append / wipe_trapq map directly to
  the chelper trapq_* functions Kalico already exposes. Allocated
  trapqs are tracked so we can identify which steppers MMS has bound
  to one of our trapqs.
- note_mcu_movequeue_activity delegates to the toolhead so its flush
  timer is kicked correctly.
- flush_all_steps calls itersolve_generate_steps only for steppers
  whose current ._trapq is one we allocated, then notifies the
  toolhead. Touching unrelated manual_steppers can cause an
  "Invalid sequence" stepcompress error if their original trapq has
  stale state from earlier moves the toolhead already flushed.
- drip_update_time mirrors the upstream segmented-flush loop so
  drip_completion can interrupt mid-move.
---
 klippy/extras/motion_queuing.py | 145 ++++++++++++++++++++++++++++++++
 1 file changed, 145 insertions(+)
 create mode 100644 klippy/extras/motion_queuing.py

diff --git a/klippy/extras/motion_queuing.py b/klippy/extras/motion_queuing.py
new file mode 100644
index 0000000..0000001
--- /dev/null	1970-01-01 01:00:00.000000000 +0100
+++ b/klippy/extras/motion_queuing.py	1970-01-01 01:00:00.000000000 +0100
@@ -0,0 +1,145 @@
+# Compatibility backport of upstream Klipper's motion_queuing module
+#
+# Provides the motion_queuing API expected by the BIGTREETECH MMS plugin
+# on top of Kalico's existing toolhead/trapq primitives. Loaded on demand
+# via printer.load_object("motion_queuing"); not used by core Kalico.
+#
+# This file may be distributed under the terms of the GNU GPLv3 license.
+import logging
+
+from klippy import chelper
+
+DRIP_SEGMENT_TIME = 0.050
+DRIP_TIME = 0.100
+
+
+class PrinterMotionQueuing:
+    def __init__(self, config):
+        self.printer = config.get_printer()
+        self.reactor = self.printer.get_reactor()
+        ffi_main, ffi_lib = chelper.get_ffi()
+        self._ffi_main = ffi_main
+        self._ffi_lib = ffi_lib
+        self.trapq_finalize_moves = ffi_lib.trapq_finalize_moves
+        self.last_step_gen_time = 0.0
+        # Trapqs allocated through us. We hold strong refs so the gc
+        # wrappers don't free the underlying C trapq while MMS still
+        # has the stepper bound to it. MMS allocates a small fixed
+        # number (one per MoveDispatch per stepper) so this is bounded.
+        self._our_trapqs = []
+
+    # ---- Trapq helpers ----
+    def allocate_trapq(self):
+        trapq = self._ffi_main.gc(
+            self._ffi_lib.trapq_alloc(), self._ffi_lib.trapq_free
+        )
+        self._our_trapqs.append(trapq)
+        return trapq
+
+    def lookup_trapq_append(self):
+        return self._ffi_lib.trapq_append
+
+    def wipe_trapq(self, trapq):
+        # Finalize all remaining moves in the trapq
+        self.trapq_finalize_moves(trapq, self.reactor.NEVER, 0.0)
+
+    def expire_trapq(self, trapq, print_time):
+        self.trapq_finalize_moves(trapq, print_time, 0.0)
+
+    # ---- Step generation ----
+    def _iter_owned_steppers(self):
+        # MMS binds an MCU_stepper to one of our allocated trapqs by
+        # calling mcu_stepper.set_trapq(<our trapq>). MCU_stepper records
+        # the active trapq as ._trapq, so we can identify steppers we
+        # actually own and skip every other manual_stepper that happens
+        # to share the printer.
+        if not self._our_trapqs:
+            return
+        for _name, obj in self.printer.lookup_objects(module="manual_stepper"):
+            steppers = getattr(obj, "steppers", None)
+            if steppers is None:
+                rail = getattr(obj, "rail", None)
+                if rail is None:
+                    continue
+                steppers = rail.get_steppers() \
+                    if hasattr(rail, "get_steppers") else [rail]
+            for stepper in steppers:
+                cur = getattr(stepper, "_trapq", None)
+                if cur is None:
+                    continue
+                for tq in self._our_trapqs:
+                    if cur == tq:
+                        yield stepper
+                        break
+
+    def _generate_owned_stepper_steps(self, flush_time):
+        for stepper in self._iter_owned_steppers():
+            try:
+                stepper.generate_steps(flush_time)
+            except Exception:
+                logging.exception(
+                    "motion_queuing: generate_steps failed for %s",
+                    stepper.get_name() if hasattr(stepper, "get_name") else "?",
+                )
+
+    def note_mcu_movequeue_activity(self, end_print_time):
+        self.last_step_gen_time = max(self.last_step_gen_time, end_print_time)
+        toolhead = self.printer.lookup_object("toolhead")
+        toolhead.note_mcu_movequeue_activity(
+            end_print_time, set_step_gen_time=True
+        )
+
+    def flush_all_steps(self):
+        flush_time = self.last_step_gen_time
+        # Generate steps only for steppers actively bound to one of our
+        # trapqs. Touching unrelated manual_steppers can produce an
+        # "Invalid sequence" stepcompress error if their original trapq
+        # has stale state from earlier moves the toolhead already
+        # flushed.
+        self._generate_owned_stepper_steps(flush_time)
+        # Notify the toolhead so its background flush_handler pushes
+        # the new stepcompress data to the MCU. Avoid calling
+        # toolhead.flush_step_generation() — that flushes the toolhead's
+        # own lookahead and can race with whatever queued the MMS move.
+        toolhead = self.printer.lookup_object("toolhead")
+        toolhead.note_mcu_movequeue_activity(
+            flush_time, set_step_gen_time=True
+        )
+
+    def check_step_generation_scan_windows(self):
+        # Kalico tracks kin_flush_delay inside the toolhead. Nothing we
+        # need to recompute on this side.
+        return
+
+    # ---- Drip (homing-style) timing ----
+    def drip_update_time(self, start_time, end_time, drip_completion):
+        toolhead = self.printer.lookup_object("toolhead")
+        mcu = toolhead.mcu
+        flush_time = start_time
+        while flush_time < end_time:
+            if drip_completion.test():
+                break
+            curtime = self.reactor.monotonic()
+            est_print_time = mcu.estimated_print_time(curtime)
+            wait_time = flush_time - est_print_time - DRIP_TIME
+            if wait_time > 0.0:
+                drip_completion.wait(curtime + wait_time)
+                continue
+            flush_time = min(flush_time + DRIP_SEGMENT_TIME, end_time)
+            self.last_step_gen_time = max(
+                self.last_step_gen_time, flush_time
+            )
+            self._generate_owned_stepper_steps(flush_time)
+            toolhead.note_mcu_movequeue_activity(
+                flush_time, set_step_gen_time=True
+            )
+        # Final flush so any generated steps are pushed to the MCU
+        self.flush_all_steps()
+
+    # ---- Stats hook (printer calls .stats() on objects that define it) ----
+    def stats(self, eventtime):
+        return False, ""
+
+
+def load_config(config):
+    return PrinterMotionQueuing(config)

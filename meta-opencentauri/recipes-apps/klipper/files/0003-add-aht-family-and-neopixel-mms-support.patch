+CMD_RESET = [0xBA]
+CMD_INIT_AHT1X = [0xE1, 0x08, 0x00]
+CMD_INIT_AHT2X = [0xBE, 0x08, 0x00]
 
-AHT10_MAX_BUSY_CYCLES = 5
+STATUS_BUSY = 0x80
+STATUS_CALIBRATED = 0x08
 
+MAX_BUSY_CYCLES = 5
+
+
+class AHTBase:
+    model = None
 

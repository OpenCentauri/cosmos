+                        "%s %s: device reported busy after "
+                        "%d cycles, resetting device"
+                        % (self.model, self.name, MAX_BUSY_CYCLES)
                     )
-                    self._reset_device()
+                    self._soft_reset()
                     data = None
                     break
 

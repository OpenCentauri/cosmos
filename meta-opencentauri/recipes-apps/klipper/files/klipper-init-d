#!/bin/sh
### BEGIN INIT INFO
# Provides:          klipper
# Required-Start:    $local_fs $remote_fs $network klipper-firmware-dsp klipper-firmware-toolhead klipper-firmware-bed
# Required-Stop:     $local_fs $remote_fs $network
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Klipper 3D Printer Firmware
### END INIT INFO

KLIPPY_EXEC="/usr/bin/python3"
KLIPPER_PRINTER_CONFIG="/etc/klipper/config/printer.cfg"
KLIPPY_ARGS="-O /usr/share/klipper/klippy/klippy.py $KLIPPER_PRINTER_CONFIG -l /board-resource/klippy.log -a /run/klippy.sock"
PIDFILE="/var/run/klipper.pid"
KLIPPER_VAR_CONFIG_BUILDER="/usr/bin/build-klipper-var-config"
KLIPPER_CONFIG_VERSION="0.0.6"
KLIPPER_CONFIG_VERSION_FILE="/etc/klipper-config.ver"
KLIPPER_CONFIG_BACKUP_DIR="/etc/klipper/config/config-backups"

ensure_klipper_config_version() {
    current_version=""

    if [ -f "$KLIPPER_CONFIG_VERSION_FILE" ]; then
        current_version="$(tr -d '[:space:]' < "$KLIPPER_CONFIG_VERSION_FILE" 2>/dev/null)"
    else
        current_version="$KLIPPER_CONFIG_VERSION"
        echo "$current_version" > "$KLIPPER_CONFIG_VERSION_FILE" || return 1
    fi

    if [ "$current_version" = "$KLIPPER_CONFIG_VERSION" ]; then
        return 0
    fi

    if [ -f "$KLIPPER_PRINTER_CONFIG" ]; then
        backup_timestamp="$(date +%Y%m%d_%H%M%S)" || return 1
        backup_file="$KLIPPER_CONFIG_BACKUP_DIR/printer-$backup_timestamp.cfg"

        mkdir -p "$KLIPPER_CONFIG_BACKUP_DIR" || return 1
        cp "$KLIPPER_PRINTER_CONFIG" "$backup_file" || return 1
        sed -i '/^#\*#/d' "$KLIPPER_PRINTER_CONFIG" || return 1
    fi

    printf '%s\n' "$KLIPPER_CONFIG_VERSION" > "$KLIPPER_CONFIG_VERSION_FILE" || return 1
}

case "$1" in
    start)
        echo "Starting klipper..."
        if ! ensure_klipper_config_version; then
            echo "Failed to update Klipper config version state"
            exit 1
        fi
        if [ -x "$KLIPPER_VAR_CONFIG_BUILDER" ]; then
            if ! "$KLIPPER_VAR_CONFIG_BUILDER"; then
                echo "Failed to generate Klipper variable config"
                exit 1
            fi
        fi
        start-stop-daemon -S -b -m -p $PIDFILE \
            -x $KLIPPY_EXEC -- $KLIPPY_ARGS
        ;;
    stop)
        echo "Stopping klipper..."
        start-stop-daemon -K -p $PIDFILE -R 10
        rm -f $PIDFILE
        ;;
    restart|force-reload)
        $0 stop
        sleep 1
        $0 start
        ;;
    status)
        if [ -f $PIDFILE ] && kill -0 $(cat $PIDFILE) 2>/dev/null; then
            echo "klipper is running (PID $(cat $PIDFILE))"
        else
            echo "klipper is not running"
            exit 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0

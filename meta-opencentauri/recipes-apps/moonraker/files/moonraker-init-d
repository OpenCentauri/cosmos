#!/bin/sh
### BEGIN INIT INFO
# Provides:          moonraker
# Required-Start:    $local_fs $remote_fs $network klipper
# Required-Stop:     $local_fs $remote_fs $network
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Moonraker API Server for Klipper
### END INIT INFO

# KSM app opt-in: pono-python-ksm sets prctl(PR_SET_MEMORY_MERGE) before
# execv to /usr/bin/python3 so moonraker's anonymous memory pages
# auto-flag VM_MERGEABLE for the ksmd kthread to scan + dedupe. Moonraker
# shares lots of jinja2 + python bytecode pages with klippy (both python3
# processes); this opt-in unlocks actual page-merging for the kernel-side
# KSM substrate. Wrapper is shipped by the kalico package (moonraker
# RDEPENDS kalico, so install order is guaranteed). Falls back to plain
# /usr/bin/python3 if pono-python-ksm missing.
MOONRAKER_EXEC="$(command -v pono-python-ksm 2>/dev/null || echo /usr/bin/python3)"
MOONRAKER_ARGS="-m moonraker.moonraker -d /etc/klipper -l /board-resource/moonraker.log -u /run/moonraker.sock"
PIDFILE="/var/run/moonraker.pid"

export PYTHONPATH="/usr/share/moonraker"
export TMPDIR="/user-resource/.tmp"

case "$1" in
    start)
        echo "Starting moonraker..."
        # Clean up OpenCentauri so moonraker doesn't index everything here
        rm -rf /user-resource/OpenCentauri
        mkdir -p /user-resource/.tmp
        mkdir -p /user-resource/gcodes

        if [ -d /etc/webui ]; then
            rm -f /etc/webui
        fi

        ln -sf "/var/www/$(config-manager ui web_ui)/" /etc/webui

        start-stop-daemon -S -b -m -p $PIDFILE \
            -x $MOONRAKER_EXEC -- $MOONRAKER_ARGS
        ;;
    stop)
        echo "Stopping moonraker..."
        start-stop-daemon -K -p $PIDFILE -R 10
        rm -f $PIDFILE
        ;;
    restart|force-reload)
        $0 stop
        sleep 1
        $0 start
        ;;
    status)
        if [ -f $PIDFILE ] && kill -0 $(cat $PIDFILE) 2>/dev/null; then
            echo "moonraker is running (PID $(cat $PIDFILE))"
        else
            echo "moonraker is not running"
            exit 1
        fi
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit 0

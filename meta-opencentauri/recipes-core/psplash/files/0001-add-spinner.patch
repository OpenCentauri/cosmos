+
+#ifdef PSPLASH_SHOW_PROGRESS_PULSE
+static void
+psplash_redraw_progress_both (PSplashFB *fb, int value)
+{
+  char *back_data = fb->bdata;
+
+  psplash_draw_progress (fb, value);
+
+  if (fb->double_buffering)

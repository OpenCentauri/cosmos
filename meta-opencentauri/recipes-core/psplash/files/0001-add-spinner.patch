+#ifdef PSPLASH_SHOW_SPINNER
+#define SPINNER_INTERVAL_USEC 100000
+#define SPINNER_SIZE          19
+#define SPINNER_GAP           8
+#define SPINNER_FRAME_COUNT   8
+
+static const int spinner_x[SPINNER_FRAME_COUNT] =
+  { 9, 14, 16, 14, 9, 4, 2, 4 };
+static const int spinner_y[SPINNER_FRAME_COUNT] =
+  { 2, 4, 9, 14, 16, 14, 9, 4 };
+
+static void
+psplash_draw_spinner_page (PSplashFB *fb, int frame)
+{
+  int bar_x, x, y, i;
+
+  bar_x = (fb->width - BAR_IMG_WIDTH) / 2;
+  x = bar_x - SPINNER_GAP - SPINNER_SIZE;
+  y = SPLIT_LINE_POS(fb) + (BAR_IMG_HEIGHT - SPINNER_SIZE) / 2;
+
+  if (x < 0)
+    x = 0;
+
+  /* Redraw every outline first, clearing the previous frame's inner dots. */
+  for (i = 0; i < SPINNER_FRAME_COUNT; i++)
+    psplash_fb_draw_rect (fb,
+                          x + spinner_x[i] - 2,
+                          y + spinner_y[i] - 2,
+                          5, 5,
+                          PSPLASH_BAR_BACKGROUND_COLOR);
+
+  /* A full-size leading dot and two progressively smaller trailing dots. */
+  i = frame % SPINNER_FRAME_COUNT;
+  psplash_fb_draw_rect (fb,
+                        x + spinner_x[i] - 1,
+                        y + spinner_y[i] - 1,
+                        3, 3,
+                        PSPLASH_BAR_COLOR);
+
+  i = (frame + SPINNER_FRAME_COUNT - 1) % SPINNER_FRAME_COUNT;
+  psplash_fb_draw_rect (fb,
+                        x + spinner_x[i] - 1,
+                        y + spinner_y[i] - 1,
+                        2, 2,
+                        PSPLASH_BAR_COLOR);
+
+  i = (frame + SPINNER_FRAME_COUNT - 2) % SPINNER_FRAME_COUNT;
+  psplash_fb_draw_rect (fb,
+                        x + spinner_x[i],
+                        y + spinner_y[i],
+                        1, 1,
+                        PSPLASH_BAR_COLOR);
+}
+
+static void
+psplash_animate_spinner (PSplashFB *fb, int frame)
+{
+  char *back_data = fb->bdata;
+
+  /* Keep both pages current without flipping otherwise unchanged content. */
+  psplash_draw_spinner_page (fb, frame);
+
+  if (fb->double_buffering)
+    {
+      fb->bdata = fb->fdata;
+      psplash_draw_spinner_page (fb, frame);
+      fb->bdata = back_data;
+    }
+}
+#endif /* PSPLASH_SHOW_SPINNER */

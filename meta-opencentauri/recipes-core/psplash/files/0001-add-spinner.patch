+#ifdef PSPLASH_SHOW_PROGRESS_PULSE
+static int psplash_progress_value = 0;
+static int psplash_pulse_x = -PSPLASH_BAR_HIGHLIGHT_WIDTH;
+
+static uint64_t
+psplash_time_usec (void)
+{
+  struct timespec now;
+  struct timeval fallback;
+
+  if (clock_gettime (CLOCK_MONOTONIC, &now) == 0)
+    return (uint64_t)now.tv_sec * 1000000 + now.tv_nsec / 1000;
+
+  gettimeofday (&fallback, NULL);
+  return (uint64_t)fallback.tv_sec * 1000000 + fallback.tv_usec;
+}
+
+static void
+psplash_timeout_until (struct timeval *timeout, uint64_t deadline)
+{
+  uint64_t now = psplash_time_usec ();
+  uint64_t remaining = deadline > now ? deadline - now : 0;
+
+  timeout->tv_sec = remaining / 1000000;
+  timeout->tv_usec = remaining % 1000000;
+}
+#endif /* PSPLASH_SHOW_PROGRESS_PULSE */
+

#!/bin/sh

set -e

KLIPPER_CONFIG_BACKUP_DIR="/etc/klipper/config/config-backups"
backup_timestamp="$(date +%Y%m%d_%H%M%S)"
backup_file="$KLIPPER_CONFIG_BACKUP_DIR/readonly-$backup_timestamp.tar.gz"

mkdir -p "$KLIPPER_CONFIG_BACKUP_DIR"
tar -czf "$backup_file" /etc/klipper/config/*-readonly
rm -rf /data/overlay-etc/upper/klipper/config/*-readonly

# These package-owned scripts have changes in this release.  The new rootfs
# performs the general image-owned init-script cleanup before mounting /etc;
# keep this focused pre-flash cleanup for launch scripts changed by this update.
rm -f \
    /data/overlay-etc/upper/init.d/moonraker \
    /data/overlay-etc/upper/init.d/ustreamer \
    /data/overlay-etc/upper/init.d/zram

sync
echo 3 > /proc/sys/vm/drop_caches
echo "Readonly configs and package-owned launch scripts reset to image defaults. A reboot may be required for files to reappear."

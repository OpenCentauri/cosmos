#!/bin/sh
# update-cosmos - in-place update from a running cosmos to a newer cosmos.
#
# Tries pre-staged local files first (USB stick or /user-resource),
# then falls back to curl. A printer with a broken network stack can
# still be updated by dropping the SWU on a USB stick.

set -e

RELEASE=$(config-manager update release)
case "$RELEASE" in
    nightly)
        FW_URL="https://github.com/OpenCentauri/yocto-opencentauri/releases/download/0.0.0/opencentauri-upgrade-elegoo-centauri-carbon1.rootfs.swu"
        ;;
    *)
        FW_URL="https://github.com/OpenCentauri/yocto-opencentauri/releases/latest/download/update.swu"
        ;;
esac

SWUFILE="/user-resource/update.swu"

# Source the SWU. Accepted shapes in priority order:
#   (a) operator placed update.swu directly at /user-resource/update.swu
#   (b) update.swu or cosmos-update.swu on USB stick or in /user-resource
#   (c) curl from GitHub releases (requires working network)
if [ -s "$SWUFILE" ]; then
    echo "update-cosmos: using pre-staged SWU at $SWUFILE (no download)"
elif LOCAL_SWU="$(find-local-firmware cosmos-update.swu update.swu 2>/dev/null)" \
        && [ -n "$LOCAL_SWU" ]; then
    echo "update-cosmos: using local SWU at $LOCAL_SWU"
    cp "$LOCAL_SWU" "$SWUFILE"
else
    echo "update-cosmos: no local firmware; falling back to network download"
    curl -k -f -S -o "$SWUFILE" -L "$FW_URL"
fi

# Install firmware
flash "$SWUFILE"

# Clean up firmware file
rm "$SWUFILE"

reboot
